@inject RoadmapService RoadmapService

<div class="mb-16">
    <div class="d-flex align-center gap-4 mb-6">
        <span class="section-badge @Category.ToLower()">@PublisherLabel</span>
        <MudText Typo="Typo.h4" Class="@($"section-title-{Category.ToLower()}")">@Title</MudText>
        <div class="section-divider @Category.ToLower() flex-1"></div>
    </div>

    <MudTable Items="_entries" Hover="true" Elevation="0" Breakpoint="Breakpoint.None">
        <HeaderContent>
            <MudTh Style="width:48px; text-align:center">#</MudTh>
            <MudTh>Game</MudTh>
            <MudTh>@(Category == "SH" ? "Flavour" : "Protagonist")</MudTh>
            <MudTh>@(Category == "SH" ? "Setting" : "Story Era")</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="text-align:center">Length</MudTh>
            <MudTh>Platform</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Class="@GetFirstCellClasses(context)" Style="text-align:center">
                @if (context.IsMovie)
                {
                    <span class="movie-icon">🎬</span>
                }
                else
                {
                    <span class="order-badge @GetOrderBadgeClass(context)">@(context.SortLabel ?? "—")</span>
                }
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <div>
                    <span class="game-name">@context.Name</span>
                    @if (!string.IsNullOrEmpty(context.GameNote))
                    {
                        <div class="game-note @GetNoteClass(context)">@context.GameNote</div>
                    }
                </div>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <span class="protagonist">@context.Protagonist</span>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <span class="protagonist">@context.StoryEra</span>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Label="true"
                         Style="@GetStatusChipStyle(context)">
                    @GetStatusText(context)
                </MudChip>
            </MudTd>
            <MudTd Class="@($"length-col {GetCellClasses(context)}")">
                <div>
                    @if (context.StarRating > 0)
                    {
                        <div>
                            <span class="star-filled">@(new string('★', context.StarRating))</span><span class="star-empty">@(new string('★', 3 - context.StarRating))</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(context.LengthLabel))
                    {
                        <div class="length-label">@context.LengthLabel</div>
                    }
                </div>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                @if (context.IsMovie)
                {
                    <span style="color:#555">@GetPlatformDisplay(context)</span>
                }
                else
                {
                    @GetPlatformMarkup(context)
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</div>

@code {
    [Parameter] public string Category { get; set; } = "RE";
    [Parameter] public string Title { get; set; } = "Resident Evil";
    [Parameter] public string PublisherLabel { get; set; } = "Capcom";

    private List<GameEntry> _entries = [];

    protected override async Task OnInitializedAsync()
    {
        _entries = await RoadmapService.GetByCategoryAsync(Category);
    }

    private string GetFirstCellClasses(GameEntry entry)
    {
        var classes = new List<string>();

        if (entry.IsMovie)
        {
            classes.Add("movie-row");
            return string.Join(" ", classes);
        }

        classes.Add("game-row");

        var stripeClass = entry.StatusLabel switch
        {
            "Done" => "stripe-done",
            "Essential" => Category == "SH" ? "stripe-essential-sh" : "stripe-essential-re",
            "Downloading" => "stripe-downloading",
            "Skip" => "stripe-skip",
            "Upcoming" => "stripe-upcoming",
            "Recommended" => "stripe-recommended",
            _ => ""
        };
        if (!string.IsNullOrEmpty(stripeClass)) classes.Add(stripeClass);

        if (entry.StatusLabel == "Done" || entry.IsCompleted) classes.Add("row-done");
        if (entry.StatusLabel == "Downloading") classes.Add("row-tonight");
        if (entry.StatusLabel == "Skip") classes.Add("row-skip");

        return string.Join(" ", classes);
    }

    private string GetCellClasses(GameEntry entry)
    {
        if (entry.IsMovie) return "movie-row";

        var classes = new List<string> { "game-row" };
        if (entry.StatusLabel == "Done" || entry.IsCompleted) classes.Add("row-done");
        if (entry.StatusLabel == "Downloading") classes.Add("row-tonight");
        if (entry.StatusLabel == "Skip") classes.Add("row-skip");

        return string.Join(" ", classes);
    }

    private string GetOrderBadgeClass(GameEntry entry) => entry.StatusLabel switch
    {
        "Downloading" => "active-now",
        "Done" => "",
        _ when entry.SortLabel == "2" && Category == "RE" => "next-up",
        _ when entry.SortLabel == "0" && Category == "SH" => "next-up",
        _ => ""
    };

    private string GetStatusChipStyle(GameEntry entry) => entry.StatusLabel switch
    {
        "Done" => "border-color:rgba(244,162,97,0.4); color:#f4a261; background:rgba(244,162,97,0.1);",
        "Essential" when Category == "SH" => "border-color:rgba(42,157,143,0.4); color:#4cc8be; background:rgba(42,157,143,0.1);",
        "Essential" => "border-color:rgba(192,57,43,0.4); color:#e05a4a; background:rgba(192,57,43,0.1);",
        "Downloading" => "border-color:rgba(58,134,255,0.5); color:#3a86ff; background:rgba(58,134,255,0.1); animation:blink 1.4s ease-in-out infinite;",
        "Skip" => "border-color:#444; color:#444;",
        "Upcoming" => "border-color:rgba(124,92,191,0.4); color:#a98be8; background:rgba(124,92,191,0.1);",
        "Recommended" => "border-color:rgba(150,150,150,0.25); color:#888; background:rgba(150,150,150,0.08);",
        "Canon" => "border-color:rgba(184,151,106,0.28); color:#b8976a; background:rgba(184,151,106,0.07);",
        "Plex" => "border-color:rgba(229,160,13,0.35); color:#e5a00d; background:rgba(229,160,13,0.1);",
        "Optional" => "border-color:rgba(110,110,110,0.25); color:#666; background:rgba(110,110,110,0.07);",
        _ => ""
    };

    private string GetStatusText(GameEntry entry) => entry.StatusLabel switch
    {
        "Done" => "✓ Done",
        "Essential" when Category == "SH" && entry.Name.Contains("SHORT MESSAGE") => "⭐ Free!",
        "Essential" when entry.Name.Contains("SEPARATE WAYS") => "⭐ Do Not Skip",
        "Essential" when Category == "SH" && entry.SortLabel == "1" => "⭐ Start Here",
        "Essential" => "⭐ Essential",
        "Downloading" => "⬇ Downloading",
        "Skip" => "⚠ Skip",
        "Upcoming" => $"🔜 {entry.StoryEra}",
        "Recommended" when entry.SortLabel?.Contains('b') == true => "Optional+",
        "Recommended" => "Recommended",
        "Canon" => "🎬 Canon",
        "Plex" => "🟡 On Plex",
        "Optional" => "Optional",
        _ => entry.StatusLabel ?? ""
    };

    private string GetNoteClass(GameEntry entry) => entry.StatusLabel switch
    {
        "Done" => "hot",
        "Downloading" => "active",
        _ => ""
    };

    private string GetPlatformDisplay(GameEntry entry)
    {
        if (!string.IsNullOrEmpty(entry.PlatformPieter)) return entry.PlatformPieter;
        if (!string.IsNullOrEmpty(entry.PlatformBrecht)) return entry.PlatformBrecht;
        return "Streaming";
    }

    private RenderFragment GetPlatformMarkup(GameEntry entry) => builder =>
    {
        var seq = 0;
        if (!string.IsNullOrEmpty(entry.PlatformBrecht))
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "platform-you");
            builder.AddContent(seq++, $"Brecht: {entry.PlatformBrecht}");
            builder.CloseElement();
        }
        if (!string.IsNullOrEmpty(entry.PlatformPieter))
        {
            if (!string.IsNullOrEmpty(entry.PlatformBrecht))
            {
                builder.OpenElement(seq++, "br");
                builder.CloseElement();
            }
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "platform-friend");
            builder.AddContent(seq++, $"Pieter: {entry.PlatformPieter}");
            builder.CloseElement();
        }
        if (entry.StatusLabel == "Skip" && entry.PlatformBrecht?.Contains("Steam") == true)
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "platform-dead");
            builder.AddContent(seq++, $"Brecht: {entry.PlatformBrecht}");
            builder.CloseElement();
        }
        if (string.IsNullOrEmpty(entry.PlatformBrecht) && string.IsNullOrEmpty(entry.PlatformPieter))
        {
            if (entry.StatusLabel is "Recommended" or "Essential" && entry.Name.Contains("Buy", StringComparison.OrdinalIgnoreCase) is false)
            {
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "platform-buy");
                builder.AddContent(seq++, "Buy needed");
                builder.CloseElement();
            }
            else
            {
                builder.AddContent(seq++, "—");
            }
        }
        if (entry.IsCouchCoop)
        {
            builder.OpenElement(seq++, "br");
            builder.CloseElement();
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "couch-tag");
            builder.AddContent(seq++, "🎮 COUCH CO-OP");
            builder.CloseElement();
        }
    };
}
