@inject RoadmapService RoadmapService
@inject IDialogService DialogService
@inject IDbContextFactory<CheapNights.Data.HorrorDbContext> DbFactory

<div class="mb-16">
    <div class="d-flex align-center gap-4 mb-6">
        <span class="section-badge @Category.ToLower()">@PublisherLabel</span>
        <MudText Typo="Typo.h4" Class="@($"section-title-{Category.ToLower()}")">@Title</MudText>
        <div class="section-divider @Category.ToLower() flex-1"></div>
    </div>

    <MudTable Items="_entries" Hover="true" Elevation="0" Breakpoint="Breakpoint.None"
              OnRowClick="OnRowClicked" T="GameEntry" Class="cursor-pointer">
        <HeaderContent>
            <MudTh Style="width:48px; text-align:center">#</MudTh>
            <MudTh>Game</MudTh>
            <MudTh>@(Category == "SH" ? "Flavour" : "Protagonist")</MudTh>
            <MudTh>@(Category == "SH" ? "Setting" : "Story Era")</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="text-align:center">Length</MudTh>
            <MudTh>Platform</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Class="@GetFirstCellClasses(context)" Style="text-align:center">
                @if (context.IsMovie)
                {
                    <span class="movie-icon">🎬</span>
                }
                else
                {
                    <span class="order-badge @GetOrderBadgeClass(context)">@(context.SortLabel ?? "—")</span>
                }
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <div>
                    <span class="game-name">@context.Name</span>
                    @if (!string.IsNullOrEmpty(context.GameNote))
                    {
                        <div class="game-note @GetNoteClass(context)">@context.GameNote</div>
                    }
                </div>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <span class="protagonist">@context.Protagonist</span>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <span class="protagonist">@context.StoryEra</span>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Label="true"
                         Style="@GetStatusChipStyle(context)">
                    @GetStatusText(context)
                </MudChip>
            </MudTd>
            <MudTd Class="@($"length-col {GetCellClasses(context)}")">
                <div>
                    @if (context.StarRating > 0)
                    {
                        <div>
                            <span class="star-filled">@(new string('★', context.StarRating))</span><span class="star-empty">@(new string('★', 3 - context.StarRating))</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(context.LengthLabel))
                    {
                        <div class="length-label">~@context.LengthLabel</div>
                    }
                </div>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                @if (context.IsMovie)
                {
                    <span style="color:#555">@GetPlatformDisplay(context)</span>
                }
                else
                {
                    @GetPlatformMarkup(context)
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</div>

@code {
    [Parameter] public string Category { get; set; } = GameConstants.Categories.ResidentEvil;
    [Parameter] public string Title { get; set; } = "Resident Evil";
    [Parameter] public string PublisherLabel { get; set; } = "Capcom";

    private List<GameEntry> _entries = [];
    private int? _nowPlayingGameId;

    protected override async Task OnInitializedAsync()
    {
        _entries = await RoadmapService.GetByCategoryAsync(Category);

        await using var db = await DbFactory.CreateDbContextAsync();
        var np = await db.NowPlaying.FirstOrDefaultAsync(n => n.Id == GameConstants.Defaults.NowPlayingId);
        _nowPlayingGameId = np?.GameEntryId;
    }

    private async Task OnRowClicked(TableRowClickEventArgs<GameEntry> args)
    {
        var entry = args.Item;
        if (entry is null) return;

        var parameters = new DialogParameters<GameEntryEditDialog> { { x => x.Entry, entry } };
        var dialogOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<GameEntryEditDialog>(entry.Name, parameters, dialogOptions);
        var dialogResult = await dialog.Result;

        if (dialogResult is not null && !dialogResult.Canceled)
        {
            _entries = await RoadmapService.GetByCategoryAsync(Category);
            StateHasChanged();
        }
    }

    private string GetFirstCellClasses(GameEntry entry)
    {
        var classes = new List<string>();

        if (entry.IsMovie)
        {
            classes.Add("movie-row");
            return string.Join(" ", classes);
        }

        classes.Add("game-row");

        var stripeClass = entry.StatusLabel switch
        {
            GameConstants.Status.Done => "stripe-done",
            GameConstants.Status.Essential => Category == GameConstants.Categories.SilentHill ? "stripe-essential-sh" : "stripe-essential-re",
            GameConstants.Status.Downloading => "stripe-downloading",
            GameConstants.Status.Skip => "stripe-skip",
            GameConstants.Status.Upcoming => "stripe-upcoming",
            GameConstants.Status.Recommended => "stripe-recommended",
            _ => ""
        };
        if (!string.IsNullOrEmpty(stripeClass)) classes.Add(stripeClass);

        if (entry.StatusLabel == GameConstants.Status.Done || entry.IsCompleted) classes.Add("row-done");
        if (entry.StatusLabel == GameConstants.Status.Downloading) classes.Add("row-tonight");
        if (entry.StatusLabel == GameConstants.Status.Skip) classes.Add("row-skip");
        if (entry.Id == _nowPlayingGameId) classes.Add("row-now-playing");
        if (IsNextUp(entry)) classes.Add("row-next-up");

        return string.Join(" ", classes);
    }

    private string GetCellClasses(GameEntry entry)
    {
        if (entry.IsMovie) return "movie-row";

        var classes = new List<string> { "game-row" };
        if (entry.StatusLabel == GameConstants.Status.Done || entry.IsCompleted) classes.Add("row-done");
        if (entry.StatusLabel == GameConstants.Status.Downloading) classes.Add("row-tonight");
        if (entry.StatusLabel == GameConstants.Status.Skip) classes.Add("row-skip");
        if (entry.Id == _nowPlayingGameId) classes.Add("row-now-playing");
        if (IsNextUp(entry)) classes.Add("row-next-up");

        return string.Join(" ", classes);
    }

    private bool IsNextUp(GameEntry entry) =>
        entry.StatusLabel is not GameConstants.Status.Downloading and not GameConstants.Status.Done
        && ((entry.SortLabel == "2" && Category == GameConstants.Categories.ResidentEvil)
         || (entry.SortLabel == "0" && Category == GameConstants.Categories.SilentHill));

    private string GetOrderBadgeClass(GameEntry entry)
    {
        if (entry.Id == _nowPlayingGameId) return "now-playing";
        if (entry.StatusLabel == GameConstants.Status.Downloading) return "active-now";
        if (entry.StatusLabel == GameConstants.Status.Done) return "";
        if (IsNextUp(entry)) return "next-up";
        return "";
    }

    private string GetStatusChipStyle(GameEntry entry) => entry.StatusLabel switch
    {
        GameConstants.Status.Done => "border-color:rgba(244,162,97,0.4); color:#f4a261; background:rgba(244,162,97,0.1);",
        GameConstants.Status.Essential when Category == GameConstants.Categories.SilentHill => "border-color:rgba(42,157,143,0.4); color:#4cc8be; background:rgba(42,157,143,0.1);",
        GameConstants.Status.Essential => "border-color:rgba(192,57,43,0.4); color:#e05a4a; background:rgba(192,57,43,0.1);",
        GameConstants.Status.Downloading => "border-color:rgba(58,134,255,0.5); color:#3a86ff; background:rgba(58,134,255,0.1); animation:blink 1.4s ease-in-out infinite;",
        GameConstants.Status.Skip => "border-color:#444; color:#444;",
        GameConstants.Status.Upcoming => "border-color:rgba(124,92,191,0.4); color:#a98be8; background:rgba(124,92,191,0.1);",
        GameConstants.Status.Recommended => "border-color:rgba(150,150,150,0.25); color:#888; background:rgba(150,150,150,0.08);",
        GameConstants.Status.Canon => "border-color:rgba(184,151,106,0.28); color:#b8976a; background:rgba(184,151,106,0.07);",
        GameConstants.Status.Plex => "border-color:rgba(229,160,13,0.35); color:#e5a00d; background:rgba(229,160,13,0.1);",
        GameConstants.Status.Optional => "border-color:rgba(110,110,110,0.25); color:#666; background:rgba(110,110,110,0.07);",
        _ => ""
    };

    private string GetStatusText(GameEntry entry) => entry.StatusLabel switch
    {
        GameConstants.Status.Done => "✓ Done",
        GameConstants.Status.Essential when Category == GameConstants.Categories.SilentHill && entry.Name.Contains("SHORT MESSAGE") => "⭐ Free!",
        GameConstants.Status.Essential when entry.Name.Contains("SEPARATE WAYS") => "⭐ Do Not Skip",
        GameConstants.Status.Essential when Category == GameConstants.Categories.SilentHill && entry.SortLabel == "1" => "⭐ Start Here",
        GameConstants.Status.Essential => "⭐ Essential",
        GameConstants.Status.Downloading => "⬇ Downloading",
        GameConstants.Status.Skip => "⚠ Skip",
        GameConstants.Status.Upcoming => $"🔜 {entry.StoryEra}",
        GameConstants.Status.Recommended when entry.SortLabel?.Contains('b') == true => "Optional+",
        GameConstants.Status.Recommended => "Recommended",
        GameConstants.Status.Canon => "🎬 Canon",
        GameConstants.Status.Plex => "🟡 On Plex",
        GameConstants.Status.Optional => "Optional",
        _ => entry.StatusLabel ?? ""
    };

    private string GetNoteClass(GameEntry entry) => entry.StatusLabel switch
    {
        GameConstants.Status.Done => "hot",
        GameConstants.Status.Downloading => "active",
        _ => ""
    };

    private string GetPlatformDisplay(GameEntry entry)
    {
        if (!string.IsNullOrEmpty(entry.PlatformPieter)) return entry.PlatformPieter;
        if (!string.IsNullOrEmpty(entry.PlatformBrecht)) return entry.PlatformBrecht;
        return "Streaming";
    }

    private RenderFragment GetPlatformMarkup(GameEntry entry) => builder =>
    {
        var seq = 0;
        if (!string.IsNullOrEmpty(entry.PlatformBrecht))
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "platform-you");
            builder.AddContent(seq++, $"{GameConstants.Players.Brecht}: {entry.PlatformBrecht}");
            builder.CloseElement();
        }
        if (!string.IsNullOrEmpty(entry.PlatformPieter))
        {
            if (!string.IsNullOrEmpty(entry.PlatformBrecht))
            {
                builder.OpenElement(seq++, "br");
                builder.CloseElement();
            }
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "platform-friend");
            builder.AddContent(seq++, $"{GameConstants.Players.Pieter}: {entry.PlatformPieter}");
            builder.CloseElement();
        }
        if (entry.StatusLabel == GameConstants.Status.Skip && entry.PlatformBrecht?.Contains(GameConstants.Platforms.Steam) == true)
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "platform-dead");
            builder.AddContent(seq++, $"{GameConstants.Players.Brecht}: {entry.PlatformBrecht}");
            builder.CloseElement();
        }
        if (string.IsNullOrEmpty(entry.PlatformBrecht) && string.IsNullOrEmpty(entry.PlatformPieter))
        {
            if (entry.StatusLabel is GameConstants.Status.Recommended or GameConstants.Status.Essential && entry.Name.Contains("Buy", StringComparison.OrdinalIgnoreCase) is false)
            {
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "platform-buy");
                builder.AddContent(seq++, "Buy needed");
                builder.CloseElement();
            }
            else
            {
                builder.AddContent(seq++, "—");
            }
        }
        if (entry.IsCouchCoop)
        {
            builder.OpenElement(seq++, "br");
            builder.CloseElement();
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "couch-tag");
            builder.AddContent(seq++, "🎮 COUCH CO-OP");
            builder.CloseElement();
        }
    };
}
