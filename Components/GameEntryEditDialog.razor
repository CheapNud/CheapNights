@inject RoadmapService RoadmapService
@inject StatusRepo StatusRepo
@inject IDbContextFactory<CheapNights.Data.HorrorDbContext> DbFactory

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
            <MudText Typo="Typo.h6">@Entry.Name</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Name" @bind-Value="Entry.Name" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudSelect T="int" Label="Category" @bind-Value="Entry.CategoryId" Variant="Variant.Outlined">
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem T="int" Value="@cat.Id">@cat.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudSelect T="int" Label="Type" @bind-Value="Entry.EntryTypeId" Variant="Variant.Outlined">
                    @foreach (var et in _entryTypes)
                    {
                        <MudSelectItem T="int" Value="@et.Id">@et.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int?" Label="Status" @bind-Value="Entry.StatusId" Variant="Variant.Outlined">
                    @foreach (var status in _statuses)
                    {
                        <MudSelectItem T="int?" Value="@((int?)status.Id)">@status.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <div class="d-flex flex-wrap gap-2 mb-2">
                    @foreach (var pill in GameConstants.ProgressNotes.All)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Style="cursor:pointer; border-color:#333; color:#888;"
                                 OnClick="@(() => ApplyProgressNote(pill))">@pill</MudChip>
                    }
                </div>
                <MudTextField T="string" Label="Game Note" @bind-Value="Entry.GameNote"
                              Variant="Variant.Outlined" Lines="2"
                              Placeholder="Arc reached, downloading, play after RE7..." />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Protagonist" @bind-Value="Entry.Protagonist" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Story Era" @bind-Value="Entry.StoryEra" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="6" sm="3">
                <MudSelect T="int" Label="Stars" @bind-Value="Entry.StarRating" Variant="Variant.Outlined">
                    <MudSelectItem T="int" Value="0">—</MudSelectItem>
                    <MudSelectItem T="int" Value="1">★</MudSelectItem>
                    <MudSelectItem T="int" Value="2">★★</MudSelectItem>
                    <MudSelectItem T="int" Value="3">★★★</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudTextField T="string" Label="Length" @bind-Value="Entry.LengthLabel"
                              Variant="Variant.Outlined" Placeholder="12h" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudTextField T="string" Label="Sort Label" @bind-Value="Entry.SortLabel"
                              Variant="Variant.Outlined" Placeholder="1, 2, 3b..." />
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudNumericField T="int" Label="Sort Order" @bind-Value="Entry.SortOrder" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int?" Label="Platform (Brecht)" @bind-Value="Entry.PlatformBrechtId"
                           Variant="Variant.Outlined" Clearable="true">
                    @foreach (var platform in _platforms)
                    {
                        <MudSelectItem T="int?" Value="@((int?)platform.Id)">@platform.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int?" Label="Platform (Pieter)" @bind-Value="Entry.PlatformPieterId"
                           Variant="Variant.Outlined" Clearable="true">
                    @foreach (var platform in _platforms)
                    {
                        <MudSelectItem T="int?" Value="@((int?)platform.Id)">@platform.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="4">
                <MudSwitch T="bool" @bind-Value="Entry.IsMovie" Label="Movie/Film" Color="Color.Info" />
            </MudItem>
            <MudItem xs="4">
                <MudSwitch T="bool" @bind-Value="Entry.IsCouchCoop" Label="Couch Co-op" Color="Color.Warning" />
            </MudItem>
            <MudItem xs="4">
                <MudSwitch T="bool" @bind-Value="Entry.IsCompleted" Label="Completed" Color="Color.Success" />
            </MudItem>

            @if (Entry.IsCompleted)
            {
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Completed Date" @bind-Date="_completedDate" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Completed Note" @bind-Value="Entry.CompletedNote"
                                  Variant="Variant.Outlined" Placeholder="Great co-op run..." />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Variant="Variant.Filled">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public GameEntry Entry { get; set; } = default!;

    private DateTime? _completedDate;
    private List<Status> _statuses = [];
    private List<Category> _categories = [];
    private List<EntryType> _entryTypes = [];
    private List<Platform> _platforms = [];

    protected override async Task OnInitializedAsync()
    {
        _statuses = await StatusRepo.GetSelectableAsync();

        await using var db = DbFactory.CreateDbContext();
        _categories = await db.Categories.OrderBy(c => c.SortOrder).AsNoTracking().ToListAsync();
        _entryTypes = await db.EntryTypes.OrderBy(e => e.SortOrder).AsNoTracking().ToListAsync();
        _platforms = await db.Platforms.OrderBy(p => p.SortOrder).AsNoTracking().ToListAsync();

        _completedDate = Entry.CompletedAt;
    }

    private async Task Save()
    {
        if (Entry.IsCompleted)
        {
            Entry.CompletedAt = _completedDate ?? DateTime.UtcNow;
        }
        else
        {
            Entry.CompletedAt = null;
            Entry.CompletedNote = null;
        }

        await RoadmapService.SaveEntryAsync(Entry);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void ApplyProgressNote(string note)
    {
        Entry.GameNote = string.IsNullOrEmpty(Entry.GameNote) ? note : $"{Entry.GameNote} — {note}";
    }

    private void Cancel() => MudDialog.Cancel();
}
