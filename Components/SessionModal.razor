@inject SessionService SessionService
@inject IDbContextFactory<CheapNights.Data.HorrorDbContext> DbFactory

<MudDialog>
    <DialogContent>
        <MudTimePicker Label="Time" @bind-Time="_selectedTime" Variant="Variant.Outlined" />

        <MudSelect T="int?" Label="Game / Film" @bind-Value="_selectedGameId" Variant="Variant.Outlined" Class="mt-3">
            <MudSelectItem T="int?" Value="@((int?)null)">🍕 Game Night (TBD)</MudSelectItem>
            @foreach (var game in _games)
            {
                <MudSelectItem T="int?" Value="@((int?)game.Id)">
                    @(game.IsMovie ? "🎬" : "🎮") @game.Name
                </MudSelectItem>
            }
        </MudSelect>

        <MudText Typo="Typo.caption" Class="mt-3 mb-2" Style="color:var(--text-dim)">LOCATION</MudText>
        <MudToggleGroup T="string" @bind-Value="_location" Style="margin-bottom:16px;">
            <MudToggleItem T="string" Value="@("brecht")">🏠 Brecht's place</MudToggleItem>
            <MudToggleItem T="string" Value="@("pieter")">🏠 Pieter's place</MudToggleItem>
        </MudToggleGroup>

        <MudTextField T="string" Label="Notes" @bind-Value="_notes" Lines="3"
                      Placeholder="Pizza ordered, bring snacks, start early..."
                      Variant="Variant.Outlined" />
    </DialogContent>
    <DialogActions>
        @if (_existingSession is not null)
        {
            <MudButton OnClick="Delete" Color="Color.Error" Variant="Variant.Text">Delete</MudButton>
        }
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Variant="Variant.Filled">Save Session</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DateTime SelectedDate { get; set; }

    private List<GameEntry> _games = [];
    private int? _selectedGameId;
    private TimeSpan? _selectedTime = new(20, 0, 0);
    private string _location = "brecht";
    private string _notes = "";
    private PlannedSession? _existingSession;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _games = await db.GameEntries
            .Where(g => g.StatusLabel != "Skip" && g.StatusLabel != "Upcoming")
            .OrderBy(g => g.SortOrder)
            .ToListAsync();

        // Check for existing session on this date
        _existingSession = await SessionService.GetByDateAsync(SelectedDate);
        if (_existingSession is not null)
        {
            _selectedGameId = _existingSession.GameEntryId;
            _selectedTime = _existingSession.ScheduledAt.TimeOfDay;
            _location = _existingSession.Location;
            _notes = _existingSession.Notes ?? "";
        }
        else
        {
            // Default to current NowPlaying game
            var np = await db.NowPlaying.FirstOrDefaultAsync(n => n.Id == 1);
            _selectedGameId = np?.GameEntryId;
        }
    }

    private async Task Save()
    {
        var scheduledAt = SelectedDate.Date + (_selectedTime ?? new TimeSpan(20, 0, 0));
        var session = _existingSession ?? new PlannedSession { Location = _location };

        session.ScheduledAt = scheduledAt;
        session.GameEntryId = _selectedGameId;
        session.Location = _location;
        session.Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes;
        session.CustomGame = _selectedGameId is null ? "Game Night (TBD)" : null;

        await SessionService.SaveSessionAsync(session);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task Delete()
    {
        if (_existingSession is not null)
        {
            await SessionService.DeleteSessionAsync(_existingSession.Id);
        }
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
