@page "/groups"
@attribute [Authorize]
@inject GroupRepo GroupRepo
@inject AppUserRepo AppUserRepo
@inject ActiveGroupService ActiveGroupService
@inject IDialogService DialogService
@inject IDbContextFactory<CheapNights.Data.CheapNightsDbContext> DbFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Groups — CheapNights</PageTitle>

<div class="mb-4">
    <MudButton Href="/" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               Size="Size.Small" Style="color:#555; text-transform:none;">
        Back
    </MudButton>
</div>

<div class="horror-header mb-12">
    <div class="horror-title mb-5">GROUPS</div>
    <MudText Typo="Typo.caption" Class="header-sub">Manage your gaming groups</MudText>
</div>

@if (!_loaded)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <div class="d-flex justify-end mb-6">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialog"
                   StartIcon="@Icons.Material.Filled.Add">
            New Group
        </MudButton>
    </div>

    @foreach (var group in _groups)
    {
        var isOwner = group.OwnerId == _currentUserId;

        <MudCard Class="mb-6" Elevation="0" Style="background:#0f0f0f; border:1px solid #222;">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex align-center gap-3">
                        @if (!string.IsNullOrEmpty(group.ThemeColor))
                        {
                            <div style="width:12px; height:12px; border-radius:50%; background:@group.ThemeColor;"></div>
                        }
                        <MudText Typo="Typo.h6">@group.Name</MudText>
                    </div>
                    @if (!string.IsNullOrEmpty(group.Description))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@group.Description</MudText>
                    }
                </CardHeaderContent>
                <CardHeaderActions>
                    @if (isOwner)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => OpenEditDialog(group))" />
                    }
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.overline" Class="mb-2" Style="letter-spacing:3px;">Members</MudText>
                <div class="d-flex flex-wrap gap-3 align-center">
                    @{
                        var members = _groupMembers.GetValueOrDefault(group.Id, []);
                    }
                    @foreach (var member in members)
                    {
                        var memberIsOwner = member.AppUserId == group.OwnerId;
                        var canRemove = isOwner && !memberIsOwner;

                        @if (canRemove)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="border-color:#333; color:#aaa;"
                                     OnClose="@(() => RemoveMember(member))" CloseIcon="@Icons.Material.Filled.Close">
                                @(member.AppUser?.DisplayName ?? member.Nickname ?? "?")
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Style="@(memberIsOwner ? "border-color:#c0392b44; color:#e05a4a;" : "border-color:#333; color:#aaa;")">
                                @(member.AppUser?.DisplayName ?? member.Nickname ?? "?")
                                @if (memberIsOwner)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small"
                                             Style="font-size:14px; margin-left:4px; color:#c0392b;" />
                                }
                            </MudChip>
                        }
                    }
                </div>

                @if (isOwner)
                {
                    var availableUsers = _availableUsers.GetValueOrDefault(group.Id, []);
                    @if (availableUsers.Count > 0)
                    {
                        <div class="d-flex align-center gap-2 mt-3">
                            <MudSelect T="int?" Label="Add member" Variant="Variant.Outlined" Dense="true"
                                       Style="max-width:240px;"
                                       Value="_selectedUserId"
                                       ValueChanged="@(val => _selectedUserId = val)">
                                @foreach (var appUser in availableUsers)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)appUser.Id)">@appUser.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                            <MudIconButton Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Primary"
                                           Size="Size.Small" Disabled="@(_selectedUserId is null)"
                                           OnClick="@(() => AddMember(group.Id))" />
                        </div>
                    }
                }

                <MudText Typo="Typo.overline" Class="mt-4 mb-2" Style="letter-spacing:3px;">Categories</MudText>
                <div class="d-flex flex-wrap gap-3">
                    @{
                        var categories = _groupCategories.GetValueOrDefault(group.Id, []);
                    }
                    @foreach (var cat in categories)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                 Style="@($"background:var(--{cat.BadgeColor}-accent, #333); color:#fff;")">
                            @cat.Code — @cat.Name
                        </MudChip>
                    }
                </div>
            </MudCardContent>
        </MudCard>
    }

    <MudCard Class="mb-6" Elevation="0" Style="background:#0f0f0f; border:1px solid #222;">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Calendar Feed</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Subscribe in any calendar app (Google, Outlook, Apple)</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (_calendarUrl is not null)
            {
                <div class="d-flex align-center gap-2">
                    <MudTextField T="string" Value="_calendarUrl" ReadOnly="true" Variant="Variant.Outlined"
                                  Dense="true" Style="font-size:12px;" />
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                   Color="Color.Primary" OnClick="CopyCalendarUrl" />
                </div>
                <MudText Typo="Typo.caption" Class="mt-2" Style="color:var(--text-dim);">
                    Includes all sessions from your groups. Do not share — this URL is personal.
                </MudText>
            }
            else
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           OnClick="GenerateCalendarUrl" StartIcon="@Icons.Material.Filled.CalendarMonth">
                    Generate Feed URL
                </MudButton>
            }
        </MudCardContent>
    </MudCard>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loaded;
    private int _currentUserId;
    private int? _selectedUserId;
    private string? _calendarUrl;
    private List<Group> _groups = [];
    private Dictionary<int, List<GroupMember>> _groupMembers = [];
    private Dictionary<int, List<Category>> _groupCategories = [];
    private Dictionary<int, List<AppUser>> _availableUsers = [];

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null) return;
        var state = await AuthState;
        var plexId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (plexId is null) return;

        var appUser = await AppUserRepo.GetByPlexIdAsync(plexId);
        if (appUser is null) return;
        _currentUserId = appUser.Id;

        await LoadGroups();
        await LoadCalendarUrl();
        _loaded = true;
    }

    private async Task LoadGroups()
    {
        _groups = await GroupRepo.GetGroupsForUserAsync(_currentUserId);
        _groupMembers = [];
        _groupCategories = [];
        _availableUsers = [];

        foreach (var group in _groups)
        {
            _groupMembers[group.Id] = await GroupRepo.GetMembersAsync(group.Id);
            _groupCategories[group.Id] = await GroupRepo.GetCategoriesAsync(group.Id);
            _availableUsers[group.Id] = await AppUserRepo.GetUsersNotInGroupAsync(group.Id);
        }
    }

    private async Task AddMember(int groupId)
    {
        if (_selectedUserId is null) return;

        var member = new GroupMember
        {
            GroupId = groupId,
            AppUserId = _selectedUserId.Value
        };
        await GroupRepo.AddMemberAsync(member, _currentUserId);
        _selectedUserId = null;
        await LoadGroups();
    }

    private async Task RemoveMember(GroupMember member)
    {
        await GroupRepo.RemoveMemberAsync(member.Id, _currentUserId);
        await LoadGroups();
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<GroupEditDialog> { { x => x.OwnerUserId, _currentUserId } };
        var dialogOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<GroupEditDialog>("New Group", parameters, dialogOptions);
        var dialogResult = await dialog.Result;

        if (dialogResult is not null && !dialogResult.Canceled)
            await LoadGroups();
    }

    private async Task OpenEditDialog(Group group)
    {
        var parameters = new DialogParameters<GroupEditDialog>
        {
            { x => x.ExistingGroup, group },
            { x => x.OwnerUserId, _currentUserId }
        };
        var dialogOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<GroupEditDialog>(group.Name, parameters, dialogOptions);
        var dialogResult = await dialog.Result;

        if (dialogResult is not null && !dialogResult.Canceled)
            await LoadGroups();
    }

    private async Task LoadCalendarUrl()
    {
        if (AuthState is null) return;
        var state = await AuthState;
        var plexId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (plexId is null) return;

        var appUser = await AppUserRepo.GetByPlexIdAsync(plexId);
        if (appUser?.CalendarToken is not null)
        {
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            _calendarUrl = $"{baseUrl}/api/calendar/{appUser.CalendarToken}.ics";
        }
    }

    private async Task GenerateCalendarUrl()
    {
        var token = await AppUserRepo.GetOrCreateCalendarTokenAsync(_currentUserId);
        var baseUrl = Navigation.BaseUri.TrimEnd('/');
        _calendarUrl = $"{baseUrl}/api/calendar/{token}.ics";
    }

    private async Task CopyCalendarUrl()
    {
        if (_calendarUrl is not null)
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _calendarUrl);
    }
}
