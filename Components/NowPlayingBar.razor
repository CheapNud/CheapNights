@implements IDisposable
@inject IDbContextFactory<CheapNights.Data.HorrorDbContext> DbFactory
@inject NowPlayingService NowPlayingService
@inject IDialogService DialogService

<div class="now-playing-bar d-flex align-center gap-4 rounded-sm pa-4 mb-12">
    <div class="now-playing-dot flex-shrink-0 rounded-circle"></div>
    <MudText Typo="Typo.overline" Class="now-playing-text">Now Playing</MudText>
    <span class="now-playing-game ml-auto">@_gameName</span>
    @if (!string.IsNullOrEmpty(_statusNote))
    {
        <span class="now-playing-note ml-2">— @_statusNote</span>
    }
    <MudIconButton Icon="@Icons.Material.Filled.Settings"
                   Size="Size.Small"
                   Class="ml-auto"
                   Style="color:#1e3a5a;"
                   OnClick="OpenDialog" />
</div>

@code {
    private string _gameName = "—";
    private string _statusNote = "";

    protected override async Task OnInitializedAsync()
    {
        NowPlayingService.OnChange += OnNowPlayingChanged;
        await LoadNowPlaying();
    }

    private async void OnNowPlayingChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadNowPlaying();
            StateHasChanged();
        });
    }

    private async Task LoadNowPlaying()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var np = await db.NowPlaying
            .Include(n => n.GameEntry)
            .FirstOrDefaultAsync(n => n.Id == GameConstants.Defaults.NowPlayingId);

        if (np?.GameEntry is not null)
        {
            _gameName = np.GameEntry.Name;
            _statusNote = np.StatusNote ?? "";
        }
        else
        {
            _gameName = "—";
            _statusNote = "";
        }
    }

    private async Task OpenDialog()
    {
        var dialogOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<NowPlayingDialog>("Now Playing", dialogOptions);
    }

    public void Dispose()
    {
        NowPlayingService.OnChange -= OnNowPlayingChanged;
    }
}
