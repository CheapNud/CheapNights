@inject SessionService SessionService
@inject GameEntryRepo GameEntryRepo
@inject NowPlayingRepo NowPlayingRepo
@inject ActiveGroupService ActiveGroupService

<MudDialog>
    <DialogContent>
        @if (!_loaded)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            @* Show sessions from OTHER groups on this date as read-only info *@
            @if (_otherGroupSessions.Count > 0)
            {
                <MudText Typo="Typo.overline" Class="mb-2" Style="letter-spacing:2px; color:var(--text-dim);">
                    OTHER GROUPS ON THIS DATE
                </MudText>
                @foreach (var otherSession in _otherGroupSessions)
                {
                    var groupColor = otherSession.Group?.ThemeColor ?? "#888";
                    var groupName = otherSession.Group?.Name ?? "?";
                    var gameName = otherSession.UseCurrentGame
                        ? (_otherNowPlayingNames.GetValueOrDefault(otherSession.GroupId) ?? "Now Playing")
                        : (otherSession.GameEntry?.Name ?? otherSession.CustomGame ?? "TBD");
                    var hostName = otherSession.HostMember?.AppUser?.DisplayName
                        ?? otherSession.HostMember?.Nickname ?? "?";

                    <div class="d-flex align-center gap-3 pa-3 rounded mb-2"
                         style="background:var(--surface2); border-left:3px solid @groupColor; opacity:0.7;">
                        <div>
                            <div class="d-flex align-center gap-2 mb-1">
                                <div style="width:8px; height:8px; border-radius:50%; background:@groupColor;"></div>
                                <MudText Typo="Typo.caption" Style="@($"color:{groupColor}; font-weight:600;")">@groupName</MudText>
                            </div>
                            <MudText Typo="Typo.body2">
                                @otherSession.ScheduledAt.ToString("HH:mm") — @gameName
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color:var(--text-dim);">
                                @hostName's place
                            </MudText>
                        </div>
                    </div>
                }
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.overline" Class="mb-2" Style="letter-spacing:2px; color:var(--text-dim);">
                    @(ActiveGroupService.ActiveGroup?.Name?.ToUpper() ?? "ACTIVE GROUP")
                </MudText>
            }

            <MudTimePicker Label="Time" @bind-Time="_selectedTime" Variant="Variant.Outlined" />

            <MudSwitch T="bool" @bind-Value="_useCurrentGame" Label="Follow Now Playing" Color="Color.Primary" Class="mt-3" />

            @if (_useCurrentGame)
            {
                <MudText Typo="Typo.body2" Class="mt-2" Style="color:var(--text-dim);">
                    Will always show whatever is set as Now Playing — currently: <strong>@(_nowPlayingName ?? "nothing")</strong>
                </MudText>
            }
            else
            {
                <Selector C="GameEntry" Items="_games" Label="Game / Film"
                          DisplayProp="@(g => $"{(g.IsMovie ? "🎬" : "🎮")} {g.Name}")"
                          Value="_selectedGame" ValueChanged="OnGameChanged"
                          DisplayPropFallback="@($"🍕 {GameConstants.Defaults.DefaultCustomGame}")"
                          Class="mt-3" />
            }

            <MudText Typo="Typo.caption" Class="mt-3 mb-2" Style="color:var(--text-dim)">LOCATION</MudText>
            <MudToggleGroup T="int?" @bind-Value="_hostMemberId" Style="margin-bottom:16px;">
                @foreach (var member in _members)
                {
                    var displayName = member.AppUser?.DisplayName ?? member.Nickname ?? "?";
                    <MudToggleItem T="int?" Value="@((int?)member.Id)">🏠 @(displayName)'s place</MudToggleItem>
                }
            </MudToggleGroup>

            <MudTextField T="string" Label="Notes" @bind-Value="_notes" Lines="3"
                          Placeholder="Pizza ordered, bring snacks, start early..."
                          Variant="Variant.Outlined" />
        }
    </DialogContent>
    <DialogActions>
        @if (_existingSession is not null)
        {
            <MudButton OnClick="Delete" Color="Color.Error" Variant="Variant.Text">Delete</MudButton>
        }
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Variant="Variant.Filled">Save Session</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DateTime SelectedDate { get; set; }

    private bool _loaded;
    private List<GameEntry> _games = [];
    private List<GroupMember> _members = [];
    private GameEntry? _selectedGame;
    private TimeSpan? _selectedTime = GameConstants.Defaults.DefaultSessionTime;
    private int? _hostMemberId;
    private string _notes = "";
    private bool _useCurrentGame = true;
    private string? _nowPlayingName;
    private PlannedSession? _existingSession;
    private List<PlannedSession> _otherGroupSessions = [];
    private Dictionary<int, string?> _otherNowPlayingNames = [];

    protected override async Task OnInitializedAsync()
    {
        var groupId = ActiveGroupService.GroupId;
        _members = ActiveGroupService.Members;
        _hostMemberId = _members.FirstOrDefault()?.Id;

        _games = await GameEntryRepo.GetSelectableGamesAsync(groupId);
        var np = await NowPlayingRepo.GetCurrentAsync(groupId);
        _nowPlayingName = np?.GameEntry?.Name;

        // Load all sessions on this date across all groups
        var allGroupIds = ActiveGroupService.AllGroupIds.ToList();
        var allDateSessions = await SessionService.GetByDateAllGroupsAsync(allGroupIds, SelectedDate);

        _existingSession = allDateSessions.FirstOrDefault(s => s.GroupId == groupId);
        _otherGroupSessions = allDateSessions.Where(s => s.GroupId != groupId).ToList();

        // Load now-playing names for other groups (for display)
        if (_otherGroupSessions.Count > 0)
        {
            var otherGroupIds = _otherGroupSessions.Select(s => s.GroupId).Distinct();
            _otherNowPlayingNames = await NowPlayingRepo.GetNowPlayingNamesAsync(otherGroupIds);
        }

        if (_existingSession is not null)
        {
            _useCurrentGame = _existingSession.UseCurrentGame;
            _selectedGame = _games.FirstOrDefault(g => g.Id == _existingSession.GameEntryId);
            _selectedTime = _existingSession.ScheduledAt.TimeOfDay;
            _hostMemberId = _existingSession.HostMemberId;
            _notes = _existingSession.Notes ?? "";
        }
        _loaded = true;
    }

    private void OnGameChanged(GameEntry game)
    {
        _selectedGame = game;
    }

    private async Task Save()
    {
        var groupId = ActiveGroupService.GroupId;
        var scheduledAt = DateTime.SpecifyKind(SelectedDate.Date + (_selectedTime ?? GameConstants.Defaults.DefaultSessionTime), DateTimeKind.Utc);
        var session = _existingSession ?? new PlannedSession { GroupId = groupId };

        session.ScheduledAt = scheduledAt;
        session.UseCurrentGame = _useCurrentGame;
        session.GameEntryId = _useCurrentGame ? null : _selectedGame?.Id;
        session.HostMemberId = _hostMemberId;
        session.Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes;
        session.CustomGame = !_useCurrentGame && _selectedGame is null ? GameConstants.Defaults.DefaultCustomGame : null;

        await SessionService.SaveSessionAsync(session);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task Delete()
    {
        if (_existingSession is not null)
        {
            await SessionService.DeleteSessionAsync(_existingSession.Id);
        }
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
