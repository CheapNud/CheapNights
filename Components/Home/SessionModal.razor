@inject SessionService SessionService
@inject GameEntryRepo GameEntryRepo
@inject NowPlayingRepo NowPlayingRepo

<MudDialog>
    <DialogContent>
        @if (!_loaded)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudTimePicker Label="Time" @bind-Time="_selectedTime" Variant="Variant.Outlined" />

            <MudSwitch T="bool" @bind-Value="_useCurrentGame" Label="Follow Now Playing" Color="Color.Primary" Class="mt-3" />

            @if (_useCurrentGame)
            {
                <MudText Typo="Typo.body2" Class="mt-2" Style="color:var(--text-dim);">
                    Will always show whatever is set as Now Playing — currently: <strong>@(_nowPlayingName ?? "nothing")</strong>
                </MudText>
            }
            else
            {
                <Selector T="GameEntry" Items="_games" Label="Game / Film"
                          DisplayProp="@(g => $"{(g.IsMovie ? "🎬" : "🎮")} {g.Name}")"
                          Value="_selectedGame" ValueChanged="@((GameEntry g) => OnGameChanged(g))"
                          DisplayPropFallback="@($"🍕 {GameConstants.Defaults.DefaultCustomGame}")"
                          Class="mt-3" />
            }

            <MudText Typo="Typo.caption" Class="mt-3 mb-2" Style="color:var(--text-dim)">LOCATION</MudText>
            <MudToggleGroup T="string" @bind-Value="_location" Style="margin-bottom:16px;">
                <MudToggleItem T="string" Value="@(GameConstants.Players.BrechtKey)">🏠 @(GameConstants.Players.Brecht)'s place</MudToggleItem>
                <MudToggleItem T="string" Value="@(GameConstants.Players.PieterKey)">🏠 @(GameConstants.Players.Pieter)'s place</MudToggleItem>
            </MudToggleGroup>

            <MudTextField T="string" Label="Notes" @bind-Value="_notes" Lines="3"
                          Placeholder="Pizza ordered, bring snacks, start early..."
                          Variant="Variant.Outlined" />
        }
    </DialogContent>
    <DialogActions>
        @if (_existingSession is not null)
        {
            <MudButton OnClick="Delete" Color="Color.Error" Variant="Variant.Text">Delete</MudButton>
        }
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Variant="Variant.Filled">Save Session</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DateTime SelectedDate { get; set; }

    private bool _loaded;
    private List<GameEntry> _games = [];
    private GameEntry? _selectedGame;
    private TimeSpan? _selectedTime = GameConstants.Defaults.DefaultSessionTime;
    private string _location = GameConstants.Players.BrechtKey;
    private string _notes = "";
    private bool _useCurrentGame = true;
    private string? _nowPlayingName;
    private PlannedSession? _existingSession;

    protected override async Task OnInitializedAsync()
    {
        _games = await GameEntryRepo.GetSelectableGamesAsync();
        var np = await NowPlayingRepo.GetCurrentAsync();
        _nowPlayingName = np?.GameEntry?.Name;

        _existingSession = await SessionService.GetByDateAsync(SelectedDate);
        if (_existingSession is not null)
        {
            _useCurrentGame = _existingSession.UseCurrentGame;
            _selectedGame = _games.FirstOrDefault(g => g.Id == _existingSession.GameEntryId);
            _selectedTime = _existingSession.ScheduledAt.TimeOfDay;
            _location = _existingSession.Location;
            _notes = _existingSession.Notes ?? "";
        }
        _loaded = true;
    }

    private void OnGameChanged(GameEntry game)
    {
        _selectedGame = game;
    }

    private async Task Save()
    {
        var scheduledAt = SelectedDate.Date + (_selectedTime ?? GameConstants.Defaults.DefaultSessionTime);
        var session = _existingSession ?? new PlannedSession { Location = _location };

        session.ScheduledAt = scheduledAt;
        session.UseCurrentGame = _useCurrentGame;
        session.GameEntryId = _useCurrentGame ? null : _selectedGame?.Id;
        session.Location = _location;
        session.Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes;
        session.CustomGame = !_useCurrentGame && _selectedGame is null ? GameConstants.Defaults.DefaultCustomGame : null;

        await SessionService.SaveSessionAsync(session);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task Delete()
    {
        if (_existingSession is not null)
        {
            await SessionService.DeleteSessionAsync(_existingSession.Id);
        }
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
