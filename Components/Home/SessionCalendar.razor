@implements IDisposable
@inject SessionService SessionService
@inject NowPlayingRepo NowPlayingRepo
@inject NowPlayingService NowPlayingService
@inject ActiveGroupService ActiveGroupService
@inject IDialogService DialogService

<MudText Typo="Typo.h5" Class="gradient-title mb-6 mt-6">SESSION PLANNER</MudText>

<!-- Calendar nav -->
<div class="d-flex align-center justify-space-between mb-5">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="PrevMonth" Size="Size.Medium" />
    <MudText Typo="Typo.h6">@_currentDate.ToString("MMMM yyyy").ToUpper()</MudText>
    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" OnClick="NextMonth" Size="Size.Medium" />
</div>

<!-- Group legend -->
@if (_groupColors.Count > 1)
{
    <div class="d-flex align-center gap-4 mb-4" style="flex-wrap:wrap;">
        @foreach (var kvp in _groupColors)
        {
            <div class="d-flex align-center gap-2">
                <div style="width:10px; height:10px; border-radius:50%; background:@kvp.Value;"></div>
                <MudText Typo="Typo.caption" Style="color:var(--text-dim);">@kvp.Key</MudText>
            </div>
        }
    </div>
}

<!-- Day labels -->
<div class="cal-grid cal-labels">
    <div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div>
    <div style="color:#e5a00d">Sat</div><div style="color:#e5a00d">Sun</div>
</div>

<!-- Calendar days -->
<div class="cal-grid mb-12">
    @foreach (var cell in _calendarCells)
    {
        if (cell.Day == 0)
        {
            <div class="cal-day empty"></div>
        }
        else
        {
            var day = cell.Day;
            var isToday = cell.IsToday;
            var isWeekend = cell.IsWeekend;
            <div class="cal-day @(isToday ? "today" : "") @(isWeekend ? "weekend" : "")"
                 @onclick="@(() => OpenSessionModal(day))">
                <div class="cal-day-num">@day</div>
                @foreach (var session in cell.Sessions)
                {
                    var groupColor = session.Group?.ThemeColor ?? "#888";
                    var gameName = ResolveGameName(session);
                    var timeStr = session.ScheduledAt.ToString("HH:mm");
                    <span class="cal-session-dot"
                          style="background:@HexToRgba(groupColor, 0.2); color:@groupColor; border-left:2px solid @groupColor;">
                        @timeStr @gameName
                    </span>
                }
            </div>
        }
    }
</div>

<!-- Upcoming sessions (all groups) -->
@if (_upcoming.Count > 0)
{
    <div class="mt-8">
        <MudText Typo="Typo.overline" Class="mb-4" Style="letter-spacing:3px;">Upcoming Sessions</MudText>
        @foreach (var session in _upcoming)
        {
            var groupColor = session.Group?.ThemeColor ?? "#888";
            var groupName = session.Group?.Name ?? "?";
            var hostLabel = GetHostDisplayLabel(session);
            <div class="upcoming-item cursor-pointer" @onclick="@(() => OpenSessionModalForDate(session.ScheduledAt))">
                <div style="width:8px; height:8px; border-radius:50%; background:@groupColor; flex-shrink:0;"
                     title="@groupName"></div>
                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="min-width:90px;">
                    @session.ScheduledAt.ToString("dd/MM/yyyy")
                </MudText>
                <MudText Typo="Typo.caption" Style="min-width:44px;">
                    @session.ScheduledAt.ToString("HH:mm")
                </MudText>
                <MudText Typo="Typo.body2" Class="flex-1">
                    @ResolveGameName(session)
                </MudText>
                <span class="upcoming-loc" style="background:@HexToRgba(groupColor, 0.15); color:@groupColor;">
                    @hostLabel
                </span>
                @if (_groupColors.Count > 1)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Style="@($"color:{groupColor}; border-color:{groupColor}; font-size:9px;")">
                        @groupName
                    </MudChip>
                }
                @if (!string.IsNullOrEmpty(session.Notes))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-disabled" Style="font-style:italic;">@session.Notes</MudText>
                }
            </div>
        }
    </div>
}

@code {
    private DateTime _currentDate = DateTime.Now;
    private List<CalendarCell> _calendarCells = [];
    private List<PlannedSession> _monthSessions = [];
    private List<PlannedSession> _upcoming = [];
    private Dictionary<int, string?> _nowPlayingNames = [];
    private Dictionary<string, string> _groupColors = [];

    protected override async Task OnInitializedAsync()
    {
        NowPlayingService.OnChange += OnNowPlayingChanged;
        ActiveGroupService.OnGroupChanged += OnGroupChanged;
        await LoadMonth();
    }

    private async Task OnGroupChanged()
    {
        await LoadMonth();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnNowPlayingChanged()
    {
        await LoadMonth();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadMonth()
    {
        var groupIds = ActiveGroupService.AllGroupIds.ToList();
        if (groupIds.Count == 0) return;

        _nowPlayingNames = await NowPlayingRepo.GetNowPlayingNamesAsync(groupIds);
        _monthSessions = await SessionService.GetSessionsForMonthAllGroupsAsync(groupIds, _currentDate.Year, _currentDate.Month);
        _upcoming = await SessionService.GetUpcomingAllGroupsAsync(groupIds, GameConstants.Defaults.UpcomingSessionCount);

        _groupColors = ActiveGroupService.UserGroups
            .Where(g => groupIds.Contains(g.Id))
            .ToDictionary(g => g.Name, g => g.ThemeColor ?? "#888");

        BuildCalendar();
    }

    private void BuildCalendar()
    {
        _calendarCells = [];
        var firstDay = new DateTime(_currentDate.Year, _currentDate.Month, 1);
        var offset = ((int)firstDay.DayOfWeek + 6) % 7; // Monday = 0
        var daysInMonth = DateTime.DaysInMonth(_currentDate.Year, _currentDate.Month);
        var today = DateTime.Today;

        for (var i = 0; i < offset; i++)
            _calendarCells.Add(new CalendarCell());

        for (var d = 1; d <= daysInMonth; d++)
        {
            var dow = (offset + d - 1) % 7;
            var daySessions = _monthSessions.Where(s => s.ScheduledAt.Day == d).ToList();
            _calendarCells.Add(new CalendarCell
            {
                Day = d,
                IsToday = d == today.Day && _currentDate.Month == today.Month && _currentDate.Year == today.Year,
                IsWeekend = dow >= 5,
                Sessions = daySessions,
            });
        }
    }

    private string ResolveGameName(PlannedSession session)
    {
        if (session.UseCurrentGame)
            return _nowPlayingNames.GetValueOrDefault(session.GroupId) ?? "Now Playing";

        return session.GameEntry?.Name ?? session.CustomGame ?? "TBD";
    }

    private string GetHostDisplayLabel(PlannedSession session)
    {
        var displayName = session.HostMember?.AppUser?.DisplayName
            ?? session.HostMember?.Nickname
            ?? "?";
        return $"{displayName}'s";
    }

    private async Task PrevMonth()
    {
        _currentDate = _currentDate.AddMonths(-1);
        await LoadMonth();
    }

    private async Task NextMonth()
    {
        _currentDate = _currentDate.AddMonths(1);
        await LoadMonth();
    }

    private Task OpenSessionModal(int day) =>
        OpenSessionModalForDate(new DateTime(_currentDate.Year, _currentDate.Month, day));

    private async Task OpenSessionModalForDate(DateTime date)
    {
        var selectedDate = date.Date;
        var parameters = new DialogParameters<SessionModal> { { x => x.SelectedDate, selectedDate } };
        var dialogOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SessionModal>(
            selectedDate.ToString("dd MMMM yyyy").ToUpper(), parameters, dialogOptions);
        var dialogResult = await dialog.Result;

        if (dialogResult is not null && !dialogResult.Canceled)
            await LoadMonth();
    }

    private static string HexToRgba(string hex, double alpha)
    {
        if (hex.StartsWith('#') && hex.Length >= 7)
        {
            var r = Convert.ToInt32(hex[1..3], 16);
            var g = Convert.ToInt32(hex[3..5], 16);
            var b = Convert.ToInt32(hex[5..7], 16);
            return $"rgba({r},{g},{b},{alpha})";
        }
        return hex;
    }

    public void Dispose()
    {
        NowPlayingService.OnChange -= OnNowPlayingChanged;
        ActiveGroupService.OnGroupChanged -= OnGroupChanged;
    }
}
