@inject RoadmapService RoadmapService
@inject StatusRepo StatusRepo
@inject GroupRepo GroupRepo
@inject ActiveGroupService ActiveGroupService
@inject IDbContextFactory<CheapNights.Data.CheapNightsDbContext> DbFactory

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
            <MudText Typo="Typo.h6">@Entry.Name</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (!_loaded)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Name" @bind-Value="Entry.Name" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <Selector C="Category" Items="_categories" Label="Category"
                          DisplayProp="@(c => c.Name)" Value="Entry.Category"
                          ValueChanged="OnCategoryChanged" OnlyDBValues="true" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <Selector C="EntryType" Items="_entryTypes" Label="Type"
                          DisplayProp="@(e => e.Name)" Value="Entry.EntryType"
                          ValueChanged="OnEntryTypeChanged" OnlyDBValues="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <Selector C="Status" Items="_statuses" Label="Status"
                          DisplayProp="@(s => s.Name)" Value="Entry.Status"
                          ValueChanged="OnStatusChanged" DisplayPropFallback="— None —" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField T="string" Label="Game Note" @bind-Value="Entry.GameNote"
                              Variant="Variant.Outlined" Lines="2"
                              Placeholder="Ethan searches for Mia — first-person horror, soft reboot..." />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Protagonist" @bind-Value="Entry.Protagonist" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Story Era" @bind-Value="Entry.StoryEra" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="6" sm="3">
                <MudSelect T="int" Label="Stars" @bind-Value="Entry.StarRating" Variant="Variant.Outlined">
                    <MudSelectItem T="int" Value="0">—</MudSelectItem>
                    <MudSelectItem T="int" Value="1">★</MudSelectItem>
                    <MudSelectItem T="int" Value="2">★★</MudSelectItem>
                    <MudSelectItem T="int" Value="3">★★★</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudTextField T="string" Label="Length" @bind-Value="Entry.LengthLabel"
                              Variant="Variant.Outlined" Placeholder="12h" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudTextField T="string" Label="Sort Label" @bind-Value="Entry.SortLabel"
                              Variant="Variant.Outlined" Placeholder="1, 2, 3b..." />
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudNumericField T="int" Label="Sort Order" @bind-Value="Entry.SortOrder" Variant="Variant.Outlined" />
            </MudItem>

            @foreach (var member in _members)
            {
                var memberId = member.Id;
                var displayName = member.AppUser?.DisplayName ?? member.Nickname ?? "?";
                <MudItem xs="12" sm="@(12 / Math.Max(_members.Count, 1))">
                    <Selector C="Platform" Items="_platforms" Label="@($"Platform ({displayName})")"
                              DisplayProp="@(p => p.Name)"
                              Value="GetMemberPlatform(memberId)"
                              ValueChanged="@(p => OnMemberPlatformChanged(memberId, p))"
                              DisplayPropFallback="— None —" />
                </MudItem>
            }

            <MudItem xs="4">
                <MudSwitch T="bool" @bind-Value="Entry.IsMovie" Label="Movie/Film" Color="Color.Info" />
            </MudItem>
            <MudItem xs="4">
                <MudSwitch T="bool" @bind-Value="Entry.IsCouchCoop" Label="Couch Co-op" Color="Color.Warning" />
            </MudItem>
            <MudItem xs="4">
                <MudSwitch T="bool" @bind-Value="Entry.IsCompleted" Label="Completed" Color="Color.Success" />
            </MudItem>

            @if (Entry.IsCompleted)
            {
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Completed Date" @bind-Date="_completedDate" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Completed Time" @bind-Value="Entry.CompletedTime"
                                  Variant="Variant.Outlined" Placeholder="13h" />
                </MudItem>
            }
        </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Variant="Variant.Filled">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public GameEntry Entry { get; set; } = default!;

    private bool _loaded;
    private DateTime? _completedDate;
    private List<Status> _statuses = [];
    private List<Category> _categories = [];
    private List<EntryType> _entryTypes = [];
    private List<Platform> _platforms = [];
    private List<GroupMember> _members = [];
    private Dictionary<int, Platform?> _memberPlatformSelections = [];

    protected override async Task OnInitializedAsync()
    {
        _members = ActiveGroupService.Members;
        _statuses = await StatusRepo.GetSelectableAsync();
        _categories = await GroupRepo.GetCategoriesAsync(ActiveGroupService.GroupId);

        await using var db = DbFactory.CreateDbContext();
        _entryTypes = await db.EntryTypes.OrderBy(e => e.SortOrder).AsNoTracking().ToListAsync();
        _platforms = await db.Platforms.OrderBy(p => p.SortOrder).AsNoTracking().ToListAsync();

        foreach (var member in _members)
        {
            var memberPlatform = Entry.MemberPlatforms
                .FirstOrDefault(mp => mp.GroupMemberId == member.Id);
            _memberPlatformSelections[member.Id] = memberPlatform?.Platform;
        }

        _completedDate = Entry.CompletedAt;
        _loaded = true;
    }

    private Platform? GetMemberPlatform(int memberId) =>
        _memberPlatformSelections.GetValueOrDefault(memberId);

    private void OnMemberPlatformChanged(int memberId, Platform platform)
    {
        _memberPlatformSelections[memberId] = platform;
    }

    private void OnCategoryChanged(Category cat)
    {
        Entry.Category = cat;
        Entry.CategoryId = cat?.Id ?? 0;
    }

    private void OnEntryTypeChanged(EntryType et)
    {
        Entry.EntryType = et;
        Entry.EntryTypeId = et?.Id ?? 0;
    }

    private void OnStatusChanged(Status status)
    {
        Entry.Status = status;
        Entry.StatusId = status?.Id;
    }

    private async Task Save()
    {
        if (Entry.IsCompleted)
        {
            Entry.CompletedAt = _completedDate is not null
                ? DateTime.SpecifyKind(_completedDate.Value, DateTimeKind.Utc)
                : DateTime.UtcNow;
        }
        else
        {
            Entry.CompletedAt = null;
            Entry.CompletedTime = null;
        }

        await RoadmapService.SaveEntryAsync(Entry);

        foreach (var (memberId, platform) in _memberPlatformSelections)
        {
            await RoadmapService.SaveMemberPlatformAsync(Entry.Id, memberId, platform?.Id);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
