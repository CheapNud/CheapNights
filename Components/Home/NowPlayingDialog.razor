@inject NowPlayingRepo NowPlayingRepo
@inject GameEntryRepo GameEntryRepo
@inject NowPlayingService NowPlayingService

<MudDialog>
    <DialogContent>
        @if (!_loaded)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <Selector C="GameEntry" Items="_games" Label="Current Game / Film"
                      DisplayProp="@(g => $"{(g.IsMovie ? "🎬" : "🎮")} {g.Name}")"
                      Value="_selectedGame" ValueChanged="@((GameEntry g) => OnGameChanged(g))"
                      DisplayPropFallback="— None —" />

            <div class="d-flex flex-wrap gap-2 mt-3 mb-2">
                @foreach (var pill in GameConstants.ProgressNotes.All)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Style="cursor:pointer; border-color:#333; color:#888;"
                             OnClick="@(() => ApplyProgressNote(pill))">@pill</MudChip>
                }
            </div>
            <MudTextField T="string" Label="Status Note" @bind-Value="_statusNote"
                          Placeholder="almost finished, just started, on the boss..."
                          Variant="Variant.Outlined" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Clear" Color="Color.Error" Variant="Variant.Text">Clear</MudButton>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Variant="Variant.Filled">Set Now Playing</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private bool _loaded;
    private List<GameEntry> _games = [];
    private GameEntry? _selectedGame;
    private string _statusNote = "";

    protected override async Task OnInitializedAsync()
    {
        _games = await GameEntryRepo.GetSelectableGamesAsync();

        var np = await NowPlayingRepo.GetCurrentAsync();
        if (np is not null)
        {
            _selectedGame = _games.FirstOrDefault(g => g.Id == np.GameEntryId);
            _statusNote = np.StatusNote ?? "";
        }
        _loaded = true;
    }

    private void OnGameChanged(GameEntry game)
    {
        _selectedGame = game;
    }

    private async Task Save()
    {
        await NowPlayingRepo.SetCurrentAsync(_selectedGame?.Id, _statusNote);
        await NowPlayingService.NotifyChangedAsync();
        MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task Clear()
    {
        await NowPlayingRepo.ClearAsync();
        await NowPlayingService.NotifyChangedAsync();
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void ApplyProgressNote(string note)
    {
        _statusNote = note;
    }

    private void Cancel() => MudDialog.Cancel();
}
