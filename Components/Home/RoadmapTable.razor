@inject RoadmapService RoadmapService
@inject IDialogService DialogService

<div class="mb-16">
    <div class="d-flex align-center gap-4 mb-6">
        <span class="section-badge @(_categoryCode?.ToLower())">@PublisherLabel</span>
        <MudText Typo="Typo.h4" Class="@($"section-title-{_categoryCode?.ToLower()}")">@Title</MudText>
        <div class="section-divider @(_categoryCode?.ToLower()) flex-1"></div>
    </div>

    <MudTable Items="_entries" Hover="true" Elevation="0" Breakpoint="Breakpoint.None"
              OnRowClick="OnRowClicked" T="GameEntry" Class="cursor-pointer">
        <HeaderContent>
            <MudTh Style="width:48px; text-align:center">#</MudTh>
            <MudTh>Game</MudTh>
            <MudTh>@(_categoryCode == "SH" ? "Flavour" : "Protagonist")</MudTh>
            <MudTh>@(_categoryCode == "SH" ? "Setting" : "Story Era")</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="text-align:center">Length</MudTh>
            <MudTh>Platform</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Class="@GetFirstCellClasses(context)" Style="text-align:center">
                @if (context.IsMovie)
                {
                    <span class="movie-icon">🎬</span>
                }
                else
                {
                    <span class="order-badge @GetOrderBadgeClass(context)">@(context.SortLabel ?? "—")</span>
                }
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <div>
                    <span class="game-name">@context.Name</span>
                    @if (!string.IsNullOrEmpty(context.GameNote))
                    {
                        <div class="game-note">@context.GameNote</div>
                    }
                    @if (context.IsCompleted && !string.IsNullOrEmpty(context.CompletedTime))
                    {
                        <div class="game-note">completed in @context.CompletedTime</div>
                    }
                </div>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <span class="protagonist">@context.Protagonist</span>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                <span class="protagonist">@context.StoryEra</span>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                @if (context.Status is not null)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Label="true"
                             Style="@GetStatusChipStyle(context)">
                        @context.Status.Name
                    </MudChip>
                }
            </MudTd>
            <MudTd Class="@($"length-col {GetCellClasses(context)}")">
                <div>
                    @if (context.StarRating > 0)
                    {
                        <div>
                            <span class="star-filled">@(new string('★', context.StarRating))</span><span class="star-empty">@(new string('★', 3 - context.StarRating))</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(context.LengthLabel))
                    {
                        <div class="length-label">~@context.LengthLabel</div>
                    }
                </div>
            </MudTd>
            <MudTd Class="@GetCellClasses(context)">
                @if (context.IsMovie)
                {
                    <span style="color:#555">@GetPlatformDisplay(context)</span>
                }
                else
                {
                    @GetPlatformMarkup(context)
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</div>

@code {
    [Parameter] public int CategoryId { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string PublisherLabel { get; set; } = "";
    [Parameter] public int? NowPlayingGameId { get; set; }

    private List<GameEntry> _entries = [];
    private string? _categoryCode;

    protected override async Task OnInitializedAsync()
    {
        _entries = await RoadmapService.GetByCategoryAsync(CategoryId);
        _categoryCode = _entries.FirstOrDefault()?.Category?.Code;
    }

    private async Task OnRowClicked(TableRowClickEventArgs<GameEntry> args)
    {
        var entry = args.Item;
        if (entry is null) return;

        var parameters = new DialogParameters<GameEntryEditDialog> { { x => x.Entry, entry } };
        var dialogOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<GameEntryEditDialog>(entry.Name, parameters, dialogOptions);
        var dialogResult = await dialog.Result;

        if (dialogResult is not null && !dialogResult.Canceled)
        {
            _entries = await RoadmapService.GetByCategoryAsync(CategoryId);
            StateHasChanged();
        }
    }

    private string StatusName(GameEntry entry) => entry.Status?.Name ?? "";

    private string GetFirstCellClasses(GameEntry entry)
    {
        var classes = new List<string> { entry.IsMovie ? "movie-row" : "game-row" };

        var statusName = StatusName(entry);
        var stripeClass = statusName switch
        {
            "Essential" => _categoryCode == "SH" ? "stripe-essential-sh" : "stripe-essential-re",
            "Recommended" => "stripe-recommended",
            "Skip" => "stripe-skip",
            "Upcoming" => "stripe-upcoming",
            _ => ""
        };
        if (!string.IsNullOrEmpty(stripeClass)) classes.Add(stripeClass);

        if (!entry.IsMovie) AddRowStateClasses(entry, classes);
        return string.Join(" ", classes);
    }

    private string GetCellClasses(GameEntry entry)
    {
        var classes = new List<string> { entry.IsMovie ? "movie-row" : "game-row" };
        if (!entry.IsMovie) AddRowStateClasses(entry, classes);
        return string.Join(" ", classes);
    }

    private void AddRowStateClasses(GameEntry entry, List<string> classes)
    {
        if (entry.IsCompleted) classes.Add("row-done");
        if (StatusName(entry) == "Skip") classes.Add("row-skip");
        if (entry.Id == NowPlayingGameId) classes.Add("row-now-playing");
        if (IsNextUp(entry)) classes.Add("row-next-up");
    }

    private bool IsNextUp(GameEntry entry) =>
        !entry.IsCompleted
        && ((_categoryCode == "RE" && entry.SortLabel == "2")
         || (_categoryCode == "SH" && entry.SortLabel == "0"));

    private string GetOrderBadgeClass(GameEntry entry)
    {
        if (entry.Id == NowPlayingGameId) return "now-playing";
        if (entry.IsCompleted) return "completed";
        if (IsNextUp(entry)) return "next-up";
        return "";
    }

    private string GetStatusChipStyle(GameEntry entry)
    {
        var status = entry.Status;
        if (status is null) return "";

        var chipColor = status.ChipColor ?? "#888";
        var chipBg = status.ChipBackground ?? "transparent";

        if (status.Name == "Essential" && _categoryCode == "SH")
        {
            chipColor = "#4cc8be";
            chipBg = "rgba(42,157,143,0.1)";
        }

        return $"border-color:{chipColor}40; color:{chipColor}; background:{chipBg};";
    }

    private static string GetPlatformDisplay(GameEntry entry)
    {
        if (entry.PlatformPieter is not null) return entry.PlatformPieter.Name;
        if (entry.PlatformBrecht is not null) return entry.PlatformBrecht.Name;
        return "Streaming";
    }

    private RenderFragment GetPlatformMarkup(GameEntry entry) => builder =>
    {
        var seq = 0;
        if (entry.PlatformBrecht is not null)
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "platform-you");
            builder.AddContent(seq++, $"{GameConstants.Players.Brecht}: {entry.PlatformBrecht.Name}");
            builder.CloseElement();
        }
        if (entry.PlatformPieter is not null)
        {
            if (entry.PlatformBrecht is not null)
            {
                builder.OpenElement(seq++, "br");
                builder.CloseElement();
            }
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "platform-friend");
            builder.AddContent(seq++, $"{GameConstants.Players.Pieter}: {entry.PlatformPieter.Name}");
            builder.CloseElement();
        }
        if (entry.PlatformBrecht is null && entry.PlatformPieter is null)
        {
            if (StatusName(entry) is "Recommended" or "Essential")
            {
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "platform-buy");
                builder.AddContent(seq++, "Buy needed");
                builder.CloseElement();
            }
            else
            {
                builder.AddContent(seq++, "—");
            }
        }
        if (entry.IsCouchCoop)
        {
            builder.OpenElement(seq++, "br");
            builder.CloseElement();
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "couch-tag");
            builder.AddContent(seq++, "🎮 COUCH CO-OP");
            builder.CloseElement();
        }
    };
}
