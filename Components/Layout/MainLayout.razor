@inherits LayoutComponentBase
@implements IDisposable
@inject GroupRepo GroupRepo
@inject AppUserRepo AppUserRepo
@inject ActiveGroupService ActiveGroupService

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="horror-app">
    <AuthorizeView>
        <Authorized>
            <div class="d-flex align-center justify-space-between mb-2">
                <div class="d-flex align-center gap-2">
                    @if (_groups.Count > 1)
                    {
                        <MudSelect T="int" Value="_selectedGroupId" ValueChanged="OnGroupSelected"
                                   Variant="Variant.Text" Dense="true" DisableUnderline="true"
                                   Style="color:#888; max-width:220px; font-size:0.85rem;">
                            @foreach (var group in _groups)
                            {
                                <MudSelectItem T="int" Value="group.Id">@group.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (_groups.Count == 1)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Style="color:#666;">
                            @_groups[0].Name
                        </MudChip>
                    }
                </div>
                <div class="d-flex align-center">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Style="color:#666;">
                        @context.User.Identity?.Name
                    </MudChip>
                    <MudButton Href="/auth/logout" Variant="Variant.Text" Size="Size.Small"
                               Style="color:#444; text-transform:none;">
                        Logout
                    </MudButton>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>
    @Body
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private MudTheme _theme = BuildDefaultTheme();
    private List<Group> _groups = [];
    private int _selectedGroupId;

    protected override async Task OnInitializedAsync()
    {
        ActiveGroupService.OnGroupChanged += OnActiveGroupChanged;
        await LoadUserGroups();
    }

    private async Task LoadUserGroups()
    {
        if (AuthState is null) return;
        var state = await AuthState;
        var plexId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (plexId is null) return;

        var appUser = await AppUserRepo.GetByPlexIdAsync(plexId);
        if (appUser is null) return;

        _groups = await GroupRepo.GetGroupsForUserAsync(appUser.Id);
        if (_groups.Count > 0)
        {
            _selectedGroupId = _groups[0].Id;
            await SelectGroup(_selectedGroupId);
        }
    }

    private async Task OnGroupSelected(int groupId)
    {
        _selectedGroupId = groupId;
        await SelectGroup(groupId);
    }

    private async Task SelectGroup(int groupId)
    {
        var group = await GroupRepo.GetWithMembersAsync(groupId);
        if (group is null) return;

        _theme = BuildTheme(group.ThemeColor);
        await ActiveGroupService.SetActiveGroupAsync(group, [.. group.Members]);
    }

    private Task OnActiveGroupChanged()
    {
        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private static MudTheme BuildTheme(string? themeColor) => new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = themeColor ?? "#c0392b",
            Secondary = "#2a9d8f",
            Background = "#080808",
            Surface = "#0f0f0f",
            AppbarBackground = "#080808",
            TextPrimary = "#e0e0e0",
            TextSecondary = "#666666",
            DrawerBackground = "#0f0f0f",
            DrawerText = "#e0e0e0",
            ActionDefault = "#e0e0e0",
            ActionDisabled = "#444444",
            Dark = "#1e1e1e",
            DarkContrastText = "#e0e0e0",
        }
    };

    private static MudTheme BuildDefaultTheme() => BuildTheme("#c0392b");

    public void Dispose()
    {
        ActiveGroupService.OnGroupChanged -= OnActiveGroupChanged;
    }
}
