@inherits LayoutComponentBase
@implements IDisposable
@inject GroupRepo GroupRepo
@inject AppUserRepo AppUserRepo
@inject ActiveGroupService ActiveGroupService

<MudThemeProvider Theme="_theme" IsDarkMode="_palette.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<style>
    :root {
        --primary: @_palette.Primary;
        --secondary: @_palette.Secondary;
        --bg: @_palette.Background;
        --surface: @_palette.Surface;
        --surface2: @_palette.Surface2;
        --border: @_palette.Border;
        --text: @_palette.TextPrimary;
        --text-dim: @_palette.TextSecondary;
        --text-mid: @_palette.TextMid;
        --gradient-start: @_palette.GradientStart;
        --gradient-mid: @_palette.GradientMid;
        --gradient-end: @_palette.GradientEnd;
    }
    html, body { background: @_palette.Background; color: @_palette.TextPrimary; }
    .mud-dialog { background: @_palette.Surface !important; border: 1px solid @_palette.Border !important; }

    @if (!_palette.ShowScanlines)
    {
        <text>body::after { display: none !important; }</text>
    }
</style>

<div class="horror-app">
    <AuthorizeView>
        <Authorized>
            <div class="d-flex align-center justify-space-between mb-2">
                <div class="d-flex align-center gap-2">
                    @if (_groups.Count > 1)
                    {
                        <MudSelect T="int" Value="_selectedGroupId" ValueChanged="OnGroupSelected"
                                   Variant="Variant.Text" Dense="true" DisableUnderline="true"
                                   Style="color:#888; max-width:220px; font-size:0.85rem;">
                            @foreach (var group in _groups)
                            {
                                <MudSelectItem T="int" Value="group.Id">
                                    <div class="d-flex align-center gap-2">
                                        @if (!string.IsNullOrEmpty(group.ThemeColor))
                                        {
                                            <div style="width:8px; height:8px; border-radius:50%; background:@group.ThemeColor;"></div>
                                        }
                                        @group.Name
                                    </div>
                                </MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (_groups.Count == 1)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Style="color:#666;">
                            @_groups[0].Name
                        </MudChip>
                    }
                </div>
                <div class="d-flex align-center">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Style="color:#666;">
                        @context.User.Identity?.Name
                    </MudChip>
                    <MudButton Href="/auth/logout" Variant="Variant.Text" Size="Size.Small"
                               Style="color:#444; text-transform:none;">
                        Logout
                    </MudButton>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>
    @Body
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private MudTheme _theme = BuildMudTheme(ThemePresets.HorrorDark);
    private ThemePalette _palette = ThemePresets.HorrorDark;
    private List<Group> _groups = [];
    private int _selectedGroupId;

    protected override async Task OnInitializedAsync()
    {
        ActiveGroupService.OnGroupChanged += OnActiveGroupChanged;
        await LoadUserGroups();
    }

    private async Task LoadUserGroups()
    {
        if (AuthState is null) return;
        var state = await AuthState;
        var plexId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (plexId is null) return;

        var appUser = await AppUserRepo.GetByPlexIdAsync(plexId);
        if (appUser is null) return;

        _groups = await GroupRepo.GetGroupsForUserAsync(appUser.Id);
        ActiveGroupService.SetUserGroups(_groups);

        if (_groups.Count > 0)
        {
            _selectedGroupId = _groups[0].Id;
            await SelectGroup(_selectedGroupId);
        }
    }

    private async Task OnGroupSelected(int groupId)
    {
        _selectedGroupId = groupId;
        await SelectGroup(groupId);
    }

    private async Task SelectGroup(int groupId)
    {
        var group = await GroupRepo.GetWithMembersAsync(groupId);
        if (group is null) return;

        ApplyTheme(group);
        await ActiveGroupService.SetActiveGroupAsync(group, [.. group.Members]);
    }

    private void ApplyTheme(Group group)
    {
        _palette = ThemePresets.Get(group.ThemePreset);

        // If group has a custom ThemeColor, override the preset's primary
        if (!string.IsNullOrEmpty(group.ThemeColor) && group.ThemeColor != _palette.Primary)
        {
            _palette = _palette with { Primary = group.ThemeColor, GradientStart = group.ThemeColor };
        }

        _theme = BuildMudTheme(_palette);
    }

    private Task OnActiveGroupChanged()
    {
        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private static MudTheme BuildMudTheme(ThemePalette palette)
    {
        var theme = new MudTheme();

        if (palette.IsDarkMode)
        {
            theme.PaletteDark = new PaletteDark
            {
                Primary = palette.Primary,
                Secondary = palette.Secondary,
                Background = palette.Background,
                Surface = palette.Surface,
                AppbarBackground = palette.AppbarBackground,
                TextPrimary = palette.TextPrimary,
                TextSecondary = palette.TextSecondary,
                DrawerBackground = palette.DrawerBackground,
                DrawerText = palette.DrawerText,
                ActionDefault = palette.ActionDefault,
                ActionDisabled = palette.ActionDisabled,
                Dark = palette.Dark,
                DarkContrastText = palette.TextPrimary,
            };
        }
        else
        {
            theme.PaletteLight = new PaletteLight
            {
                Primary = palette.Primary,
                Secondary = palette.Secondary,
                Background = palette.Background,
                Surface = palette.Surface,
                AppbarBackground = palette.AppbarBackground,
                TextPrimary = palette.TextPrimary,
                TextSecondary = palette.TextSecondary,
                DrawerBackground = palette.DrawerBackground,
                DrawerText = palette.DrawerText,
                ActionDefault = palette.ActionDefault,
                ActionDisabled = palette.ActionDisabled,
                Dark = palette.Dark,
            };
        }

        return theme;
    }

    public void Dispose()
    {
        ActiveGroupService.OnGroupChanged -= OnActiveGroupChanged;
    }
}
